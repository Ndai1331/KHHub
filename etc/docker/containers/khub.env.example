# Copy to khub.env (same folder as khub.yml) and adjust. Docker Compose reads variables from a .env file in the working directory when you run compose.
#
POSTGRES_PASSWORD=myPassword

# Public HTTPS URLs (nginx terminates TLS; see containers/nginx/khhub.conf)
KHUB_PUBLIC_AUTH=https://auth.khub.id.vn
KHUB_PUBLIC_WEB=https://www.khub.id.vn
KHUB_PUBLIC_API=https://api.khub.id.vn
KHUB_PUBLIC_MOBILE_API=https://m-api.khub.id.vn

# Optional Web: cold-start thread culture for /api/abp/application-localization (default en in khub.yml web service)
# App__DefaultCulture=vi
#
# Web OIDC: khub.yml sets AuthServer__IsOnK8s=true so metadata is fetched at http://authserver while the browser still uses KHUB_PUBLIC_AUTH.
