{
  "ConnectionStrings": {
  "AdministrationService": "Host=localhost;Port=5432;Database=KHHub_Administration;User ID=postgres;Password=myPassword;",
  "AuditLoggingService": "Host=localhost;Port=5432;Database=KHHub_AuditLogging;User ID=postgres;Password=myPassword;",
  "AbpBlobStoring": "Host=localhost;Port=5432;Database=KHHub_BlobStoring;User ID=postgres;Password=myPassword;",
  "GdprService": "Host=localhost;Port=5432;Database=KHHub_Gdpr;User ID=postgres;Password=myPassword;",
  "LanguageService": "Host=localhost;Port=5432;Database=KHHub_Language;User ID=postgres;Password=myPassword;"
  },
  "App": {
    "CorsOrigins": "http://localhost:44394",
    "EnablePII": false,
    "HealthCheckUrl": "/health-status"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": ["FromLogContext"],
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "Logs/logs.txt"
              }
            }
          ]
        }
      },
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "Swagger": {
    "IsEnabled": true
  },
  "AuthServer": {
    "Authority": "http://localhost:44315",
    "MetaAddress": "http://localhost:44315",
    "RequireHttpsMetadata": false,
    "SwaggerClientId": "SwaggerTestUI",
    "Audience": "LanguageService"
  },
  "Redis": {
    "Configuration": "localhost:6379"
  },
  "RabbitMQ": {
    "Connections": {
      "Default": {
        "HostName": "localhost"
      }
    },
    "EventBus": {
      "ClientName": "KHHub_LanguageService",
      "ExchangeName": "KHHub"
    }
  },
  "AbpDistributedCache": {
    "KeyPrefix": "KHHub:"
  },
  "DataProtection": {
    "ApplicationName": "KHHub",
    "Keys": "KHHub-Protection-Keys"
  },
  "ElasticSearch": {
    "IsLoggingEnabled": true,
    "Url": "http://localhost:9200"
  },
  "StringEncryption": {
    "DefaultPassPhrase": "h4QkP6MXlEVsvOGa"
  }
}