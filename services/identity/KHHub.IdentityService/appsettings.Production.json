{
  "ConnectionStrings": {
    "IdentityService": "Host=postgres;Port=5432;Database=KHHub_Identity;User ID=postgres;Password=myPassword;Timeout=240;",
    "AuditLoggingService": "Host=postgres;Port=5432;Database=KHHub_AuditLogging;User ID=postgres;Password=myPassword;Timeout=240;",
    "LanguageService": "Host=postgres;Port=5432;Database=KHHub_Language;User ID=postgres;Password=myPassword;Timeout=240;",
    "AdministrationService": "Host=postgres;Port=5432;Database=KHHub_Administration;User ID=postgres;Password=myPassword;Timeout=240;",
    "AbpBlobStoring": "Host=postgres;Port=5432;Database=KHHub_BlobStoring;User ID=postgres;Password=myPassword;Timeout=240;"
  },
  "App": {
    "CorsOrigins": "http://webgateway,http://mobilegateway"
  },
  "AuthServer": {
    "Authority": "http://authserver",
    "MetaAddress": "http://authserver",
    "RequireHttpsMetadata": false
  },
  "Redis": {
    "Configuration": "redis:6379"
  },
  "RabbitMQ": {
    "Connections": {
      "Default": {
        "HostName": "rabbitmq"
      }
    }
  },
  "ElasticSearch": {
    "Url": "http://elasticsearch:9200"
  },
  "OpenIddict": {
    "Applications": {
      "Web": {
        "RootUrl": "http://web/"
      },
      "ReactNative": {
        "RootUrl": "khhub://"
      },
      "MobileGateway": {
        "RootUrl": "http://mobilegateway/"
      },
      "WebGateway": {
        "RootUrl": "http://webgateway/"
      }
    },
    "Resources": {
      "AuthServer": {
        "RootUrl": "http://authserver"
      },
      "IdentityService": {
        "RootUrl": "http://identity"
      },
      "AuditLoggingService": {
        "RootUrl": "http://auditlogging"
      },
      "GdprService": {
        "RootUrl": "http://gdpr"
      },
      "AIManagementService": {
        "RootUrl": "http://aimanagement"
      },
      "LanguageService": {
        "RootUrl": "http://language"
      },
      "AdministrationService": {
        "RootUrl": "http://administration"
      },
      "MasterDataService": {
        "RootUrl": "http://masterdata"
      }
