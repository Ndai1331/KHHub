{
  "App": {
    "CorsOrigins": "http://localhost:4200,http://localhost:44360,http://localhost:44354,khhubmauiblazor://",
    "HealthCheckUrl": "/health-status"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "Logs/logs.txt"
              }
            }
          ]
        }
      },
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "AuthServer": {
    "SwaggerClientId": "SwaggerTestUI"
  },
  "ElasticSearch": {
    "IsLoggingEnabled": true,
    "Url": "http://localhost:9200"
  },
  "Swagger": {
    "IsEnabled": true
  },
  "ReverseProxy": {
    "Routes": {
      "AbpApi": {
        "ClusterId": "Administration",
        "Match": {
          "Path": "/api/abp/{**catch-all}"
        }
      },
      "SettingManagement": {
        "ClusterId": "Administration",
        "Match": {
          "Path": "/api/setting-management/{**catch-all}"
        }
      },
      "FeatureManagement": {
        "ClusterId": "Administration",
        "Match": {
          "Path": "/api/feature-management/{**catch-all}"
        }
      },
      "PermissionManagement": {
        "ClusterId": "Administration",
        "Match": {
          "Path": "/api/permission-management/{**catch-all}"
        }
      },
      "LeptonXThemeManagement": {
        "ClusterId": "Administration",
        "Match": {
          "Path": "/api/lepton-x-theme-management/{**catch-all}"
        }
      },
      "TextTemplateManagement": {
        "ClusterId": "Administration",
        "Match": {
          "Path": "/api/text-template-management/{**catch-all}"
        }
      },
      "OpenIddict": {
        "ClusterId": "Identity",
        "Match": {
          "Path": "/api/openiddict/{**catch-all}"
        }
      },
      "AdministrationSwagger": {
        "ClusterId": "Administration",
        "Match": {
          "Path": "/swagger-json/Administration/swagger/v1/swagger.json"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/swagger-json/Administration"
          }
        ]
      },
      "Account": {
        "ClusterId": "AuthServer",
        "Match": {
          "Path": "/api/account/{**catch-all}"
        }
      },
      "AccountAdmin": {
        "ClusterId": "AuthServer",
        "Match": {
          "Path": "/api/account-admin/{**catch-all}"
        }
      },
      "AuthServerSwagger": {
        "ClusterId": "AuthServer",
        "Match": {
          "Path": "/swagger-json/AuthServer/swagger/v1/swagger.json"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/swagger-json/AuthServer"
          }
        ]
      },
      "AuditLogging": {
        "ClusterId": "AuditLogging",
        "Match": {
          "Path": "/api/audit-logging/{**catch-all}"
        }
      },
      "AuditLoggingSwagger": {
        "ClusterId": "AuditLogging",
        "Match": {
          "Path": "/swagger-json/AuditLogging/swagger/v1/swagger.json"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/swagger-json/AuditLogging"
          }
        ]
      },
      "Gdpr": {
        "ClusterId": "Gdpr",
        "Match": {
          "Path": "/api/gdpr/{**catch-all}"
        }
      },
      "GdprSwagger": {
        "ClusterId": "Gdpr",
        "Match": {
          "Path": "/swagger-json/Gdpr/swagger/v1/swagger.json"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/swagger-json/Gdpr"
          }
        ]
      },
      "AIManagement": {
        "ClusterId": "AIManagement",
        "Match": {
          "Path": "/api/ai-management/{**catch-all}"
        }
      },
      "ChatCompletion": {
        "ClusterId": "AIManagement",
        "Match": {
          "Path": "/api/chat-completion/{**catch-all}"
        }
      },
      "AIManagementSwagger": {
        "ClusterId": "AIManagement",
        "Match": {
          "Path": "/swagger-json/AIManagement/swagger/v1/swagger.json"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/swagger-json/AIManagement"
          }
        ]
      },
      "Language": {
        "ClusterId": "Language",
        "Match": {
          "Path": "/api/language-management/{**catch-all}"
        }
      },
      "LanguageSwagger": {
        "ClusterId": "Language",
        "Match": {
          "Path": "/swagger-json/Language/swagger/v1/swagger.json"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/swagger-json/Language"
          }
        ]
      },
      "Identity": {
        "ClusterId": "Identity",
        "Match": {
          "Path": "/api/identity/{**catch-all}"
        }
      },
      "IdentitySwagger": {
        "ClusterId": "Identity",
        "Match": {
          "Path": "/swagger-json/Identity/swagger/v1/swagger.json"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/swagger-json/Identity"
          }
        ]
      },
      "MasterData": {
        "ClusterId": "MasterData",
        "Match": {
          "Path": "/api/masterdata/{**catch-all}"
        }
      },
      "MasterDataLegacyPath": {
        "ClusterId": "MasterData",
        "Match": {
          "Path": "/api/master-data/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/master-data" },
          { "PathPrefix": "/api/masterdata" }
        ]
      },
      "MasterDataIntegration": {
        "ClusterId": "MasterData",
        "Match": {
          "Path": "/integration-api/masterdata/{**catch-all}"
        }
      },
      "MasterDataSwagger": {
        "ClusterId": "MasterData",
        "Match": {
          "Path": "/swagger-json/MasterData/swagger/v1/swagger.json"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/swagger-json/MasterData"
          }
        ]
      }
    },
    "Clusters": {
      "AuthServer": {
        "Destinations": {
          "AuthServer": {
            "Address": "http://localhost:44315/"
          }
        }
      },
      "Administration": {
        "Destinations": {
          "Administration": {
            "Address": "http://localhost:44396/"
          }
        }
      },
      "AuditLogging": {
        "Destinations": {
          "AuditLogging": {
            "Address": "http://localhost:44390/"
          }
        }
      },
      "Gdpr": {
        "Destinations": {
          "Gdpr": {
            "Address": "http://localhost:44355/"
          }
        }
      },
      "AIManagement": {
        "Destinations": {
          "AIManagement": {
            "Address": "http://localhost:44350/"
          }
        }
      },
      "Language": {
        "Destinations": {
          "Language": {
            "Address": "http://localhost:44362/"
          }
        }
      },
      "Identity": {
        "Destinations": {
          "Identity": {
            "Address": "http://localhost:44333/"
          }
        }
      },
      "MasterData": {
        "Destinations": {
          "MasterData": {
            "Address": "http://localhost:44381"
          }
        }
      }
    }
  }
}