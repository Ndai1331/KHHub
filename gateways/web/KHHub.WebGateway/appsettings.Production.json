{
  "App": {
    "CorsOrigins": "https://www.khub.id.vn,https://api.khub.id.vn,https://auth.khub.id.vn,https://m-api.khub.id.vn",
    "HealthCheckUrl": "/health-status",
    "HealthUiCheckUrl": "http://127.0.0.1:80/health-status"
  },
  "AuthServer": {
    "SwaggerClientId": "SwaggerTestUI"
  },
  "ElasticSearch": {
    "IsLoggingEnabled": true,
    "Url": "http://elasticsearch:9200"
  },
  "Swagger": {
    "IsEnabled": false
  },
  "Redis": {
    "Configuration": "redis:6379"
  },
  "RabbitMQ": {
    "Connections": {
      "Default": {
        "HostName": "rabbitmq"
      }
    }
  },
  "ReverseProxy": {
    "Routes": {
      "MasterData": {
        "ClusterId": "MasterData",
        "Match": {
          "Path": "/api/masterdata/{**catch-all}"
        }
      },
      "MasterDataLegacyPath": {
        "ClusterId": "MasterData",
        "Match": {
          "Path": "/api/master-data/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/master-data" },
          { "PathPrefix": "/api/masterdata" }
        ]
      },
      "MasterDataIntegration": {
        "ClusterId": "MasterData",
        "Match": {
          "Path": "/integration-api/masterdata/{**catch-all}"
        }
      },
      "MasterDataSwagger": {
        "ClusterId": "MasterData",
        "Match": {
          "Path": "/swagger-json/MasterData/swagger/v1/swagger.json"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/swagger-json/MasterData"
          }
        ]
      }
    },
    "Clusters": {
      "AuthServer": {
        "Destinations": {
          "AuthServer": {
            "Address": "http://authserver:80/"
          }
        }
      },
      "Administration": {
        "Destinations": {
          "Administration": {
            "Address": "http://administration:80/"
          }
        }
      },
      "AuditLogging": {
        "Destinations": {
          "AuditLogging": {
            "Address": "http://auditlogging:80/"
          }
        }
      },
      "Gdpr": {
        "Destinations": {
          "Gdpr": {
            "Address": "http://gdpr:80/"
          }
        }
      },
      "AIManagement": {
        "Destinations": {
          "AIManagement": {
            "Address": "http://aimanagement:80/"
          }
        }
      },
      "Language": {
        "Destinations": {
          "Language": {
            "Address": "http://language:80/"
          }
        }
      },
      "Identity": {
        "Destinations": {
          "Identity": {
            "Address": "http://identity:80/"
          }
        }
      },
      "MasterData": {
        "Destinations": {
          "MasterData": {
            "Address": "http://masterdata:80/"
          }
        }
      }
    }
  }
}
