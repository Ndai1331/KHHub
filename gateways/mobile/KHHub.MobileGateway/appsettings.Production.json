{
  "App": {
    "CorsOrigins": "khhub://,https://localhost,http://mobilegateway"
  },
  "ElasticSearch": {
    "Url": "http://elasticsearch:9200"
  },
  "Redis": {
    "Configuration": "redis:6379"
  },
  "RabbitMQ": {
    "Connections": {
      "Default": {
        "HostName": "rabbitmq"
      }
    }
  },
  "ReverseProxy": {
    "Clusters": {
      "AuthServer": {
        "Destinations": {
          "AuthServer": {
            "Address": "http://authserver/"
          }
        }
      },
      "Administration": {
        "Destinations": {
          "Administration": {
            "Address": "http://administration/"
          }
        }
      },
      "Identity": {
        "Destinations": {
          "Identity": {
            "Address": "http://identity/"
          }
        }
      },
      "Language": {
        "Destinations": {
          "Language": {
            "Address": "http://language/"
          }
        }
      },
      "MasterData": {
        "Destinations": {
          "MasterData": {
            "Address": "http://masterdata/"
          }
        }
      }
    }
  }
}
