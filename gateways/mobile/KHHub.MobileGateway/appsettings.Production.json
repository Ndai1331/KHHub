{
  "App": {
    "CorsOrigins": "khhub://,https://localhost,http://mobilegateway"
  },
  "ElasticSearch": {
    "Url": "http://elasticsearch:9200"
  },
  "Redis": {
    "Configuration": "redis:6379"
  },
  "RabbitMQ": {
    "Connections": {
      "Default": {
        "HostName": "rabbitmq"
      }
    }
  },
  "ReverseProxy": {
    "Routes": {
      "MasterData": {
        "ClusterId": "MasterData",
        "Match": {
          "Path": "/api/masterdata/{**catch-all}"
        }
      },
      "MasterDataLegacyPath": {
        "ClusterId": "MasterData",
        "Match": {
          "Path": "/api/master-data/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/master-data" },
          { "PathPrefix": "/api/masterdata" }
        ]
      },
      "MasterDataSwagger": {
        "ClusterId": "MasterData",
        "Match": {
          "Path": "/swagger-json/MasterData/swagger/v1/swagger.json"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/swagger-json/MasterData"
          }
        ]
      }
    },
    "Clusters": {
      "AuthServer": {
        "Destinations": {
          "AuthServer": {
            "Address": "http://authserver/"
          }
        }
      },
      "Administration": {
        "Destinations": {
          "Administration": {
            "Address": "http://administration/"
          }
        }
      },
      "Identity": {
        "Destinations": {
          "Identity": {
            "Address": "http://identity/"
          }
        }
      },
      "Language": {
        "Destinations": {
          "Language": {
            "Address": "http://language/"
          }
        }
      },
      "MasterData": {
        "Destinations": {
          "MasterData": {
            "Address": "http://masterdata/"
          }
        }
      }
    }
  }
}
