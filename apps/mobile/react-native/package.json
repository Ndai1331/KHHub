{
  "name": "khhub",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start --port 19000",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "create:local-proxy": "npx local-ssl-proxy --source ${SOURCE_PORT:-443} --target 8081 --cert localhost.pem --key localhost-key.pem",
