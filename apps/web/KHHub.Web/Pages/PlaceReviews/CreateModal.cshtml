@page
@using Microsoft.AspNetCore.Mvc.Localization
@using KHHub.MasterDataService.Localization
@using Volo.Abp.AspNetCore.Mvc.UI.Bootstrap.TagHelpers.Modal
@using KHHub.Web.Pages.PlaceReviews
@inject IHtmlLocalizer<MasterDataServiceResource> L
@model CreateModalModel
@{
    Layout = null;
}
<form data-ajaxForm="true" asp-page="/PlaceReviews/CreateModal" autocomplete="off">
    <abp-modal id="PlaceReviewCreateModal"
               size="ExtraLarge"
               scrollable="true"
               centered="true">
        <abp-modal-header title="@L["NewPlaceReview"].Value"></abp-modal-header>
        <abp-modal-body>
            <abp-row class="g-3 align-items-start">
                <abp-column size-md="_6">
                    @if (Model.PlaceReview.PlaceId == Guid.Empty)
                    {
                        <label class="form-label" asp-for="PlaceReview.PlaceId">@L["Place"].Value</label>
                        <select asp-for="PlaceReview.PlaceId"
                                class="auto-complete-select"
                                data-autocomplete-api-url="@Url.Content("~/api/masterdata/place-reviews/place-lookup")"
                                data-autocomplete-display-property="displayName"
                                data-autocomplete-value-property="id"
                                data-autocomplete-items-property="items"
                                data-autocomplete-filter-param-name="filter"
                                data-autocomplete-allow-clear="false"
                                data-autocomplete-placeholder="@L["Search"].Value">
                        </select>
                        <span asp-validation-for="PlaceReview.PlaceId" class="text-danger d-block"></span>
                    }
                    else
                    {
                        <input type="hidden" asp-for="PlaceReview.PlaceId" />
                        <p class="text-muted small mb-3">@L["PlaceReviewLinkedPlaceHint"].Value</p>
                    }
                    <div class="mt-3">
                        <abp-input asp-for="PlaceReview.Rating" label="@L["Rating"].Value" />
                    </div>
                    <abp-input asp-for="PlaceReview.Title" label="@L["Title"].Value" />
                    <abp-select asp-for="PlaceReview.Status" label="@L["Status"].Value" />
                    <abp-input asp-for="PlaceReview.LikeCount" label="@L["LikeCount"].Value" />
                    <abp-input asp-for="PlaceReview.UserId" label="@L["UserId"].Value" />
                </abp-column>
                <abp-column size-md="_6">
                    <label class="form-label" asp-for="PlaceReview.Comment">@L["Comment"].Value</label>
                    <textarea asp-for="PlaceReview.Comment"
                              class="form-control"
                              rows="14"
                              autocomplete="off"></textarea>
                    <span asp-validation-for="PlaceReview.Comment" class="text-danger d-block"></span>
                </abp-column>
            </abp-row>
        </abp-modal-body>
        <abp-modal-footer buttons="@(AbpModalButtons.Cancel|AbpModalButtons.Save)">
        </abp-modal-footer>
    </abp-modal>
</form>
