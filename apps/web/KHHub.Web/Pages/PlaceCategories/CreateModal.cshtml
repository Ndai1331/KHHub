@page
@using Microsoft.AspNetCore.Mvc.Localization
@using KHHub.MasterDataService.Localization
@using Volo.Abp.AspNetCore.Mvc.UI.Bootstrap.TagHelpers.Modal
@using KHHub.Web.Pages.PlaceCategories
@using System.Globalization
@inject IHtmlLocalizer<MasterDataServiceResource> L
@model CreateModalModel
@{
    Layout = null;
}
<form data-ajaxForm="true" asp-page="/PlaceCategories/CreateModal" autocomplete="off">
    <abp-modal id="PlaceCategoryCreateModal">
        <abp-modal-header title="@L["NewPlaceCategory"].Value"></abp-modal-header>
        <abp-modal-body>
@*//<suite-custom-code-block-1>*@
@*//</suite-custom-code-block-1>*@
            <abp-input asp-for="PlaceCategory.Name"    />
            <abp-input asp-for="PlaceCategory.Slug"    />
            <abp-input asp-for="PlaceCategory.Description" text-area   />
            <abp-input asp-for="PlaceCategory.Icon"    />
            <abp-input asp-for="PlaceCategory.Color"    />
            <abp-input asp-for="PlaceCategory.ParentId"    />
            <abp-input asp-for="PlaceCategory.DisplayOrder"    />
            <abp-input asp-for="PlaceCategory.IsActive"    />
@*//<suite-custom-code-block-2>*@
@*//</suite-custom-code-block-2>*@
@*//<suite-custom-code-block-3>*@
@*//</suite-custom-code-block-3>*@
        </abp-modal-body>
        <abp-modal-footer buttons="@(AbpModalButtons.Cancel|AbpModalButtons.Save)">
@*//<suite-custom-code-block-4>*@
@*//</suite-custom-code-block-4>*@
        </abp-modal-footer>
    </abp-modal>
</form>