@page
@using Microsoft.AspNetCore.Mvc.Localization
@using KHHub.MasterDataService.Localization
@using KHHub.Web.Pages.EntityFiles
@using Volo.Abp.AspNetCore.Mvc.UI.Bootstrap.TagHelpers.Modal
@using KHHub.MasterDataService.Services.EntityFiles; 
@using System.Globalization
@inject IHtmlLocalizer<MasterDataServiceResource> L
@model EditModalModel
@{
    Layout = null;
}
<form data-ajaxForm="true" asp-page="/EntityFiles/EditModal" autocomplete="off">
    <abp-modal id="EntityFileEditModal">
        <abp-modal-header title="@L["Update"].Value"></abp-modal-header>
        <abp-modal-body>
@*//<suite-custom-code-block-1>*@
@*//</suite-custom-code-block-1>*@
            <abp-input asp-for="Id" />
                    <abp-input asp-for="EntityFile.ConcurrencyStamp" hidden="true" suppress-label="true"/>
            <abp-input asp-for="EntityFile.EntityType"    />
            <abp-input asp-for="EntityFile.EntityId"    />
            <abp-input asp-for="EntityFile.Collection"    />
            <abp-input asp-for="EntityFile.SortOrder"    />
            <abp-input asp-for="EntityFile.IsPrimary"    />
                                <div class="form-group">
                <label for="EntityFile_MediaFileId">@L["MediaFile"]</label>
                <select id="EntityFile_MediaFileId"
                         name="EntityFile.MediaFileId"
                         class="custom-select form-control"
                         data-value="@Model.EntityFile.MediaFileId" required>
                    @if (Model.MediaFile != null)
                    {
                        <option value="@Model.EntityFile.MediaFileId">@Model.MediaFile.FileName</option>
                    }
                </select>
            </div>
@*//<suite-custom-code-block-2>*@
@*//</suite-custom-code-block-2>*@
@*//<suite-custom-code-block-3>*@
@*//</suite-custom-code-block-3>*@
        </abp-modal-body>
        <abp-modal-footer buttons="@(AbpModalButtons.Cancel|AbpModalButtons.Save)">
@*//<suite-custom-code-block-4>*@
@*//</suite-custom-code-block-4>*@
        </abp-modal-footer>
    </abp-modal>
</form>