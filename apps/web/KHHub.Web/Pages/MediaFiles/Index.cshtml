@page
@using Microsoft.AspNetCore.Authorization
@using Volo.Abp.AspNetCore.Mvc.UI.Layout
@using KHHub.MasterDataService.Permissions
@using KHHub.Web.Pages.MediaFiles
@using KHHub.Web.Navigation
@using Microsoft.AspNetCore.Mvc.Localization
@using KHHub.MasterDataService.Localization
@inject IHtmlLocalizer<MasterDataServiceResource> L
@inject IAuthorizationService Authorization
@model IndexModel
@inject IPageLayout PageLayout
@{
    PageLayout.Content.Title = L["MediaFiles"].Value;
    PageLayout.Content.MenuItemName = KHHubMenus.MediaFiles;
}
@section styles
{
@*//<suite-custom-code-block-1>*@
@*//</suite-custom-code-block-1>*@
}
@section scripts
{
    <abp-script src="/Pages/MediaFiles/index.js" />
@*//<suite-custom-code-block-2>*@
@*//</suite-custom-code-block-2>*@
}
@section content_toolbar {
    <abp-button id="ExportToExcelButton" text="@L["ExportToExcel"].Value" icon="download" size="Small" button-type="Primary" />
    @if (await Authorization.IsGrantedAsync(MasterDataServicePermissions.MediaFiles.Create))
    {
        <abp-button id="NewMediaFileButton" text="@L["NewMediaFile"].Value" icon="plus" size="Small" button-type="Primary" />
    }
@*//<suite-custom-code-block-3>*@
@*//</suite-custom-code-block-3>*@
}
@*//<suite-custom-code-block-4>*@
@*//</suite-custom-code-block-4>*@
<abp-card>
    <abp-card-body>
		<abp-row class="mb-3">
            <abp-column size-md="_8" size-lg="_10">
                <div class="mb-3">
                    <form id="SearchForm" autocomplete="off">
                        <div class="input-group">
                            <input class="form-control page-search-filter-text" id="FilterText" placeholder="@L["Search"]"/>
                            <abp-button button-type="Primary" type="submit" icon="search"/>
                        </div>
                    </form>
                </div>
            </abp-column>
            <abp-column size-md="_4" size-lg="_2">
                <div class="mb-3">
                    <abp-button style="width:100%" id="AdvancedFilterSectionToggler" button-type="Outline_Primary">
                        @L["Filters"]<i aria-hidden="true" class="fa ms-1 fa-angle-down"></i>
                    </abp-button>
                </div>
            </abp-column>
        </abp-row>
        <abp-row id="AdvancedFilterSection" class="mt-3" style="display: none;">
            <abp-column size="_3">
                <abp-input asp-for="FileNameFilter" label="@L["FileName"].Value" />
            </abp-column>
            <abp-column size="_3">
                <abp-input asp-for="OriginalFileNameFilter" label="@L["OriginalFileName"].Value" />
            </abp-column>
            <abp-column size="_3">
                <abp-input asp-for="ExtensionFilter" label="@L["Extension"].Value" />
            </abp-column>
            <abp-column size="_3">
                <abp-input asp-for="ContentTypeFilter" label="@L["ContentType"].Value" />
            </abp-column>
            <abp-column size="_3">
                <abp-input asp-for="StorageProviderFilter" label="@L["StorageProvider"].Value" />
            </abp-column>
            <abp-column size="_3">
                <abp-input asp-for="BucketFilter" label="@L["Bucket"].Value" />
            </abp-column>
            <abp-column size="_3">
                <abp-input asp-for="FolderFilter" label="@L["Folder"].Value" />
            </abp-column>
            <abp-column size="_3">
                <abp-input asp-for="PathFilter" label="@L["Path"].Value" />
            </abp-column>
            <abp-column size="_3">
                <abp-input asp-for="UrlFilter" label="@L["Url"].Value" />
            </abp-column>
            <abp-column size="_3">
                <abp-input asp-for="ChecksumFilter" label="@L["Checksum"].Value" />
            </abp-column>
            <abp-column size="_3">
                <abp-input asp-for="WidthFilterMin" label="@L["MinWidth"].Value" />
            </abp-column>
            <abp-column size="_3">
                <abp-input asp-for="WidthFilterMax" label="@L["MaxWidth"].Value" />
            </abp-column>
            <abp-column size="_3">
                <abp-input asp-for="HeightFilterMin" label="@L["MinHeight"].Value" />
            </abp-column>
            <abp-column size="_3">
                <abp-input asp-for="HeightFilterMax" label="@L["MaxHeight"].Value" />
            </abp-column>
            <abp-column size="_3">
                <abp-select asp-for="FileTypeFilter" label="@L["FileType"].Value" />
            </abp-column>
            <abp-column size="_3">
                <abp-select asp-for="StatusFilter" label="@L["Status"].Value" />
            </abp-column>
@*//<suite-custom-code-block-5>*@
@*//</suite-custom-code-block-5>*@
        </abp-row>
        <div id="bulk-delete-context-menu" class="d-none">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <p class="lead mb-0 d-none" id="items-selected-info-message"></p>
                <div>
                    <button class="btn btn-outline-secondary d-none mx-1" id="select-all-items-btn"></button>
                    <button class="btn btn-outline-secondary d-none mx-1" id="clear-selection-btn">
                        @L["ClearSelection"]
                    </button>
                    <button class="btn btn-danger mx-1" id="delete-selected-items">
                        <i class="fa fa-trash"></i> @L["Delete"]
                    </button>
                </div>
            </div>
            <hr class="my-1 mx-0"/>
        </div>
        <abp-table striped-rows="true" id="MediaFilesTable">
            <thead>
				<tr>
				    <th id="BulkDeleteCheckboxTheader"><input type="checkbox" id="select_all" class="form-check-input" /></th>
					<th>@L["Actions"]</th>
					<th>@L["FileName"]</th>
					<th>@L["OriginalFileName"]</th>
					<th>@L["Extension"]</th>
					<th>@L["ContentType"]</th>
					<th>@L["Size"]</th>
					<th>@L["StorageProvider"]</th>
					<th>@L["Bucket"]</th>
					<th>@L["Folder"]</th>
					<th>@L["Path"]</th>
					<th>@L["Url"]</th>
					<th>@L["Checksum"]</th>
					<th>@L["Width"]</th>
					<th>@L["Height"]</th>
					<th>@L["Duration"]</th>
					<th>@L["FileType"]</th>
					<th>@L["Status"]</th>
@*//<suite-custom-code-block-6>*@
@*//</suite-custom-code-block-6>*@
				</tr>
            </thead>
        </abp-table>
    </abp-card-body>
</abp-card>
@*//<suite-custom-code-block-7>*@
@*//</suite-custom-code-block-7>*@