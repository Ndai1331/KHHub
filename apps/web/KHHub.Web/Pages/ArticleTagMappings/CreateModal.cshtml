@page
@using Microsoft.AspNetCore.Mvc.Localization
@using KHHub.MasterDataService.Localization
@using Volo.Abp.AspNetCore.Mvc.UI.Bootstrap.TagHelpers.Modal
@using KHHub.Web.Pages.ArticleTagMappings
@using System.Globalization
@inject IHtmlLocalizer<MasterDataServiceResource> L
@model CreateModalModel
@{
    Layout = null;
}
<form data-ajaxForm="true" asp-page="/ArticleTagMappings/CreateModal" autocomplete="off">
    <abp-modal id="ArticleTagMappingCreateModal">
        <abp-modal-header title="@L["NewArticleTagMapping"].Value"></abp-modal-header>
        <abp-modal-body>
@*//<suite-custom-code-block-1>*@
@*//</suite-custom-code-block-1>*@
            <abp-input asp-for="ArticleTagMapping.IsPrimary"    />
            <abp-input asp-for="ArticleTagMapping.Order"    />
                                <abp-select asp-for="ArticleTagMapping.ArticleTagId" asp-items="Model.ArticleTagLookupListRequired" label="@L["ArticleTag"].Value"/>
            <abp-select asp-for="ArticleTagMapping.ArticleId" asp-items="Model.ArticleLookupListRequired" label="@L["Article"].Value"/>
@*//<suite-custom-code-block-2>*@
@*//</suite-custom-code-block-2>*@
@*//<suite-custom-code-block-3>*@
@*//</suite-custom-code-block-3>*@
        </abp-modal-body>
        <abp-modal-footer buttons="@(AbpModalButtons.Cancel|AbpModalButtons.Save)">
@*//<suite-custom-code-block-4>*@
@*//</suite-custom-code-block-4>*@
        </abp-modal-footer>
    </abp-modal>
</form>