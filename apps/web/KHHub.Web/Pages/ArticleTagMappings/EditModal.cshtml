@page
@using Microsoft.AspNetCore.Mvc.Localization
@using KHHub.MasterDataService.Localization
@using KHHub.Web.Pages.ArticleTagMappings
@using Volo.Abp.AspNetCore.Mvc.UI.Bootstrap.TagHelpers.Modal
@inject IHtmlLocalizer<MasterDataServiceResource> L
@model EditModalModel
@{
    Layout = null;
}
<form data-ajaxForm="true" asp-page="/ArticleTagMappings/EditModal" autocomplete="off">
    <abp-modal id="ArticleTagMappingEditModal">
        <abp-modal-header title="@L["Update"].Value"></abp-modal-header>
        <abp-modal-body>
            <abp-input asp-for="Id" />
            <abp-input asp-for="ArticleTagMapping.ConcurrencyStamp" hidden="true" suppress-label="true" />
            <abp-row class="align-items-start">
                <abp-column size-md="_6">
                    <abp-input asp-for="ArticleTagMapping.IsPrimary" label="@L["IsPrimary"].Value" />
                </abp-column>
                <abp-column size-md="_6">
                    <abp-input asp-for="ArticleTagMapping.Order" label="@L["Order"].Value" />
                </abp-column>
            </abp-row>
            <abp-row class="align-items-start">
                <abp-column size-md="_6">
                    <label class="form-label" asp-for="ArticleTagMapping.ArticleTagId">@L["ArticleTag"].Value</label>
                    <select asp-for="ArticleTagMapping.ArticleTagId"
                            class="auto-complete-select"
                            data-autocomplete-api-url="@Url.Content("~/api/masterdata/article-tag-mappings/article-tag-lookup")"
                            data-autocomplete-display-property="displayName"
                            data-autocomplete-value-property="id"
                            data-autocomplete-items-property="items"
                            data-autocomplete-filter-param-name="filter"
                            data-autocomplete-allow-clear="false"
                            data-autocomplete-placeholder="@L["Search"].Value">
                    </select>
                    <span asp-validation-for="ArticleTagMapping.ArticleTagId" class="text-danger d-block"></span>
                </abp-column>
                <abp-column size-md="_6">
                    <label class="form-label" asp-for="ArticleTagMapping.ArticleId">@L["Article"].Value</label>
                    <select asp-for="ArticleTagMapping.ArticleId"
                            class="auto-complete-select"
                            data-autocomplete-api-url="@Url.Content("~/api/masterdata/article-tag-mappings/article-lookup")"
                            data-autocomplete-display-property="displayName"
                            data-autocomplete-value-property="id"
                            data-autocomplete-items-property="items"
                            data-autocomplete-filter-param-name="filter"
                            data-autocomplete-allow-clear="false"
                            data-autocomplete-placeholder="@L["Search"].Value">
                    </select>
                    <span asp-validation-for="ArticleTagMapping.ArticleId" class="text-danger d-block"></span>
                </abp-column>
            </abp-row>
        </abp-modal-body>
        <abp-modal-footer buttons="@(AbpModalButtons.Cancel|AbpModalButtons.Save)">
        </abp-modal-footer>
    </abp-modal>
</form>
