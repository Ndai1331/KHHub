@page
@using Microsoft.AspNetCore.Mvc.Localization
@using KHHub.MasterDataService.Localization
@using KHHub.Web.Pages.PlaceFavorites
@using Volo.Abp.AspNetCore.Mvc.UI.Bootstrap.TagHelpers.Modal
@using KHHub.MasterDataService.Services.PlaceFavorites; 
@using System.Globalization
@inject IHtmlLocalizer<MasterDataServiceResource> L
@model EditModalModel
@{
    Layout = null;
}
<form data-ajaxForm="true" asp-page="/PlaceFavorites/EditModal" autocomplete="off">
    <abp-modal id="PlaceFavoriteEditModal">
        <abp-modal-header title="@L["Update"].Value"></abp-modal-header>
        <abp-modal-body>
@*//<suite-custom-code-block-1>*@
@*//</suite-custom-code-block-1>*@
            <abp-input asp-for="Id" />
                    <abp-input asp-for="PlaceFavorite.ConcurrencyStamp" hidden="true" suppress-label="true"/>
            <abp-input asp-for="PlaceFavorite.UserId"    />
                                <div class="form-group">
                <label for="PlaceFavorite_PlaceId">@L["Place"]</label>
                <select id="PlaceFavorite_PlaceId"
                         name="PlaceFavorite.PlaceId"
                         class="custom-select form-control"
                         data-value="@Model.PlaceFavorite.PlaceId" required>
                    @if (Model.Place != null)
                    {
                        <option value="@Model.PlaceFavorite.PlaceId">@Model.Place.Name</option>
                    }
                </select>
            </div>
@*//<suite-custom-code-block-2>*@
@*//</suite-custom-code-block-2>*@
@*//<suite-custom-code-block-3>*@
@*//</suite-custom-code-block-3>*@
        </abp-modal-body>
        <abp-modal-footer buttons="@(AbpModalButtons.Cancel|AbpModalButtons.Save)">
@*//<suite-custom-code-block-4>*@
@*//</suite-custom-code-block-4>*@
        </abp-modal-footer>
    </abp-modal>
</form>