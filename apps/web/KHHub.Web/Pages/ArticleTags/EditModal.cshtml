@page
@using Microsoft.AspNetCore.Mvc.Localization
@using KHHub.MasterDataService.Localization
@using KHHub.Web.Pages.ArticleTags
@using Volo.Abp.AspNetCore.Mvc.UI.Bootstrap.TagHelpers.Modal
@inject IHtmlLocalizer<MasterDataServiceResource> L
@model EditModalModel
@{
    Layout = null;
}
<form data-ajaxForm="true" asp-page="/ArticleTags/EditModal" autocomplete="off">
    <abp-modal id="ArticleTagEditModal">
        <abp-modal-header title="@L["Update"].Value"></abp-modal-header>
        <abp-modal-body>
            <abp-input asp-for="Id" />
            <abp-input asp-for="ArticleTag.ConcurrencyStamp" hidden="true" suppress-label="true" />
            <div class="mb-3">
                <label class="form-label" for="article-tag-name-input">@L["Name"].Value</label>
                <input asp-for="ArticleTag.Name"
                       type="text"
                       class="form-control"
                       id="article-tag-name-input"
                       autocomplete="off" />
                <span asp-validation-for="ArticleTag.Name" class="text-danger d-block"></span>
            </div>
            <div class="mb-3">
                <label class="form-label" for="article-tag-slug-input">@L["ArticleTagSlug"].Value</label>
                <input asp-for="ArticleTag.Slug"
                       type="text"
                       class="form-control bg-body-secondary"
                       id="article-tag-slug-input"
                       readonly="readonly"
                       tabindex="-1"
                       aria-readonly="true"
                       autocomplete="off" />
                <span asp-validation-for="ArticleTag.Slug" class="text-danger d-block"></span>
            </div>
            <abp-input asp-for="ArticleTag.Description" text-area="true" label="@L["Description"].Value" />
            <abp-input asp-for="ArticleTag.UsageCount" label="@L["UsageCount"].Value" />
        </abp-modal-body>
        <abp-modal-footer buttons="@(AbpModalButtons.Cancel|AbpModalButtons.Save)">
        </abp-modal-footer>
    </abp-modal>
</form>
