@page
@using Microsoft.AspNetCore.Authorization
@using Volo.Abp.AspNetCore.Mvc.UI.Layout
@using KHHub.MasterDataService.Permissions
@using KHHub.Web.Pages.ArticleTags
@using KHHub.Web.Navigation
@using Microsoft.AspNetCore.Mvc.Localization
@using KHHub.MasterDataService.Localization
@inject IHtmlLocalizer<MasterDataServiceResource> L
@inject IAuthorizationService Authorization
@model IndexModel
@inject IPageLayout PageLayout
@{
    PageLayout.Content.Title = L["ArticleTags"].Value;
    PageLayout.Content.MenuItemName = KHHubMenus.ArticleTags;
}
@section styles
{
@*//<suite-custom-code-block-1>*@
@*//</suite-custom-code-block-1>*@
}
@section scripts
{
    <abp-script src="/Pages/ArticleTags/article-tag-slug.js" />
    <abp-script src="/Pages/ArticleTags/index.js" />
@*//<suite-custom-code-block-2>*@
@*//</suite-custom-code-block-2>*@
}
@section content_toolbar {
    <abp-button id="ExportToExcelButton" text="@L["ExportToExcel"].Value" icon="download" size="Small" button-type="Primary" />
    @if (await Authorization.IsGrantedAsync(MasterDataServicePermissions.ArticleTags.Create))
    {
        <abp-button id="NewArticleTagButton" text="@L["NewArticleTag"].Value" icon="plus" size="Small" button-type="Primary" />
    }
}
<abp-card>
    <abp-card-body>
        <abp-row class="mb-3">
            <abp-column size-md="_12">
                <label class="form-label" for="FilterText">@L["Search"].Value</label>
                <form id="SearchForm" autocomplete="off">
                    <div class="input-group">
                        <input class="form-control page-search-filter-text" id="FilterText" placeholder="@L["Search"]" />
                        <abp-button button-type="Primary" type="submit" icon="search" />
                    </div>
                </form>
            </abp-column>
        </abp-row>
        <abp-table striped-rows="true" hoverable-rows="true" id="ArticleTagsTable">
            <thead>
                <tr>
                    <th style="width: 90px;">@L["Actions"]</th>
                    <th>@L["Name"]</th>
                    <th>@L["Slug"]</th>
                    <th>@L["Description"]</th>
                    <th>@L["UsageCount"]</th>
                </tr>
            </thead>
        </abp-table>
    </abp-card-body>
</abp-card>
