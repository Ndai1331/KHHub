@page
@using Microsoft.AspNetCore.Authorization
@using Volo.Abp.AspNetCore.Mvc.UI.Layout
@using KHHub.MasterDataService.Permissions
@using KHHub.Web.Pages.Places
@using KHHub.Web.Navigation
@using Microsoft.AspNetCore.Mvc.Localization
@using KHHub.MasterDataService.Localization
@inject IHtmlLocalizer<MasterDataServiceResource> L
@inject IAuthorizationService Authorization
@model IndexModel
@inject IPageLayout PageLayout
@{
    PageLayout.Content.Title = L["Places"].Value;
    PageLayout.Content.MenuItemName = KHHubMenus.Places;
}
@section styles
{
<style>
    .place-thumb {
        height: 36px;
        width: 36px;
        min-width: 36px;
        min-height: 36px;
        border-radius: 50% !important;
        object-fit: cover;
    }
</style>
}
@section scripts
{
    <partial name="~/Pages/Shared/_MediaPreviewSettings.cshtml" />
    <script src="~/Pages/Shared/khhub-media-preview.js" asp-append-version="true"></script>
    <abp-script src="/Pages/Places/index.js" />
}
@section content_toolbar {
    <abp-button id="ExportToExcelButton" text="@L["ExportToExcel"].Value" icon="download" size="Small" button-type="Primary" />
    @if (await Authorization.IsGrantedAsync(MasterDataServicePermissions.Places.Create))
    {
        <abp-button id="NewPlaceButton" text="@L["NewPlace"].Value" icon="plus" size="Small" button-type="Primary" />
    }
}
<abp-card>
    <abp-card-body>
        <abp-row class="mb-3">
            <abp-column size-md="_12">
                <label class="form-label" for="FilterText">@L["Search"].Value</label>
                <form id="SearchForm" autocomplete="off">
                    <div class="input-group">
                        <input class="form-control page-search-filter-text" id="FilterText" placeholder="@L["Search"]" />
                        <abp-button button-type="Primary" type="submit" icon="search" />
                    </div>
                </form>
            </abp-column>
            <abp-column size-md="_4">
                <abp-select asp-for="StatusFilter" asp-items="@Model.PlaceStatusList" label="@L["Status"].Value" />
            </abp-column>
            <abp-column size-md="_4">
                <abp-select asp-for="PriceRangeFilter" asp-items="@Model.PriceRangeList" label="@L["PriceRange"].Value" />
            </abp-column>
            <abp-column size-md="_4">
                <label class="form-label" asp-for="PlaceCategoryIdFilter">@L["PlaceCategory"].Value</label>
                <select asp-for="PlaceCategoryIdFilter"
                        class="auto-complete-select"
                        data-autocomplete-api-url="@Url.Content("~/api/masterdata/places/place-category-lookup")"
                        data-autocomplete-display-property="displayName"
                        data-autocomplete-value-property="id"
                        data-autocomplete-items-property="items"
                        data-autocomplete-filter-param-name="filter"
                        data-autocomplete-allow-clear="true"
                        data-autocomplete-placeholder="@L["Search"].Value">
                </select>
            </abp-column>
            <abp-column size-md="_4">
                <label class="form-label" asp-for="ProvinceIdFilter">@L["Province"].Value</label>
                <select asp-for="ProvinceIdFilter"
                        class="auto-complete-select"
                        data-autocomplete-api-url="@Url.Content("~/api/masterdata/places/province-lookup")"
                        data-autocomplete-display-property="displayName"
                        data-autocomplete-value-property="id"
                        data-autocomplete-items-property="items"
                        data-autocomplete-filter-param-name="filter"
                        data-autocomplete-allow-clear="true"
                        data-autocomplete-placeholder="@L["Search"].Value">
                </select>
            </abp-column>
            <abp-column size-md="_4">
                <label class="form-label" asp-for="WardIdFilter">@L["Ward"].Value</label>
                <select asp-for="WardIdFilter"
                        class="auto-complete-select"
                        data-autocomplete-api-url="@Url.Content("~/api/masterdata/places/ward-lookup")"
                        data-autocomplete-display-property="displayName"
                        data-autocomplete-value-property="id"
                        data-autocomplete-items-property="items"
                        data-autocomplete-filter-param-name="filter"
                        data-autocomplete-allow-clear="true"
                        data-autocomplete-placeholder="@L["Search"].Value">
                </select>
            </abp-column>
            <abp-column size-md="_4">
                <label class="form-label" asp-for="IsFeaturedFilter">@L["IsFeatured"].Value</label>
                <select asp-for="IsFeaturedFilter" asp-items="Model.IsFeaturedFilterItems" class="form-select"></select>
            </abp-column>
            <abp-column size-md="_4">
                <label class="form-label" asp-for="IsHotFilter">@L["IsHot"].Value</label>
                <select asp-for="IsHotFilter" asp-items="Model.IsHotFilterItems" class="form-select"></select>
            </abp-column>
            <abp-column size-md="_4">
                <label class="form-label" asp-for="IsVerifiedFilter">@L["IsVerified"].Value</label>
                <select asp-for="IsVerifiedFilter" asp-items="Model.IsVerifiedFilterItems" class="form-select"></select>
            </abp-column>
        </abp-row>
        <abp-table striped-rows="true" hoverable-rows="true" id="PlacesTable">
            <thead>
                <tr>
                    <th style="width: 90px;">@L["Actions"]</th>
                    <th style="width: 56px;">@L["ThumbnailUrl"]</th>
                    <th>@L["Name"]</th>
                    <th>@L["PlaceCategory"]</th>
                    <th>@L["Province"]</th>
                    <th>@L["Ward"]</th>
                    <th>@L["PriceRange"]</th>
                    <th>@L["Status"]</th>
                    <th>@L["IsFeatured"]</th>
                    <th>@L["IsHot"]</th>
                    <th>@L["IsVerified"]</th>
                </tr>
            </thead>
        </abp-table>
    </abp-card-body>
</abp-card>
