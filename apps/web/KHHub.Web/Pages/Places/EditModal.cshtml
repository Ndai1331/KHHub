@page
@using Microsoft.AspNetCore.Mvc.Localization
@using KHHub.MasterDataService.Localization
@using KHHub.Web.Pages.Places
@using Volo.Abp.AspNetCore.Mvc.UI.Bootstrap.TagHelpers.Modal
@using KHHub.MasterDataService.Services.Places; 
@using System.Globalization
@inject IHtmlLocalizer<MasterDataServiceResource> L
@model EditModalModel
@{
    Layout = null;
}
<form data-ajaxForm="true" asp-page="/Places/EditModal" autocomplete="off">
    <abp-modal id="PlaceEditModal">
        <abp-modal-header title="@L["Update"].Value"></abp-modal-header>
        <abp-modal-body>
@*//<suite-custom-code-block-1>*@
@*//</suite-custom-code-block-1>*@
            <abp-input asp-for="Id" />
                    <abp-input asp-for="Place.ConcurrencyStamp" hidden="true" suppress-label="true"/>
            <abp-input asp-for="Place.Name"    />
            <abp-input asp-for="Place.Slug"    />
            <abp-input asp-for="Place.ShortDescription" text-area   />
            <abp-input asp-for="Place.Description" text-area   />
            <abp-input asp-for="Place.ThumbnailUrl"    />
            <abp-input asp-for="Place.CoverImageUrl"    />
            <abp-input asp-for="Place.Address"    />
            <abp-input asp-for="Place.Latitude"   data-val="false" />
            <abp-input asp-for="Place.Longituded"   data-val="false" />
            <abp-input asp-for="Place.PhoneNumber"    />
            <abp-input asp-for="Place.Email"    />
            <abp-input asp-for="Place.Website"    />
            <abp-input asp-for="Place.OpeningHours"    />
            <abp-select asp-for="Place.PriceRange"    />
            <abp-input asp-for="Place.GoogleMapUrl"    />
            <abp-select asp-for="Place.Status"    />
            <abp-input asp-for="Place.ViewCount"    />
            <abp-input asp-for="Place.FavoriteCount"    />
            <abp-input asp-for="Place.ReviewCount"    />
            <abp-input asp-for="Place.RatingAveraged"   data-val="false" />
            <abp-input asp-for="Place.RatingTotal"    />
            <abp-input asp-for="Place.IsFeatured"    />
            <abp-input asp-for="Place.IsHot"    />
            <abp-input asp-for="Place.IsVerified"    />
            <abp-input asp-for="Place.SeoTitle"    />
            <abp-input asp-for="Place.SeoDescription" text-area   />
            <abp-input asp-for="Place.SeoKeywords"    />
                                <div class="form-group">
                <label for="Place_PlaceCategoryId">@L["PlaceCategory"]</label>
                <select id="Place_PlaceCategoryId"
                         name="Place.PlaceCategoryId"
                         class="custom-select form-control"
                         data-value="@Model.Place.PlaceCategoryId" required>
                    @if (Model.PlaceCategory != null)
                    {
                        <option value="@Model.Place.PlaceCategoryId">@Model.PlaceCategory.Name</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label for="Place_ProvinceId">@L["Province"]</label>
                <select id="Place_ProvinceId"
                         name="Place.ProvinceId"
                         class="custom-select form-control"
                         data-value="@Model.Place.ProvinceId" required>
                    @if (Model.Province != null)
                    {
                        <option value="@Model.Place.ProvinceId">@Model.Province.Name</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label for="Place_WardId">@L["Ward"]</label>
                <select id="Place_WardId"
                         name="Place.WardId"
                         class="custom-select form-control"
                         data-value="@Model.Place.WardId" required>
                    @if (Model.Ward != null)
                    {
                        <option value="@Model.Place.WardId">@Model.Ward.Name</option>
                    }
                </select>
            </div>
@*//<suite-custom-code-block-2>*@
@*//</suite-custom-code-block-2>*@
@*//<suite-custom-code-block-3>*@
@*//</suite-custom-code-block-3>*@
        </abp-modal-body>
        <abp-modal-footer buttons="@(AbpModalButtons.Cancel|AbpModalButtons.Save)">
@*//<suite-custom-code-block-4>*@
@*//</suite-custom-code-block-4>*@
        </abp-modal-footer>
    </abp-modal>
</form>