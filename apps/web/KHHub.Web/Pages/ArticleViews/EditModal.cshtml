@page
@using Microsoft.AspNetCore.Mvc.Localization
@using KHHub.MasterDataService.Localization
@using KHHub.Web.Pages.ArticleViews
@using Volo.Abp.AspNetCore.Mvc.UI.Bootstrap.TagHelpers.Modal
@using KHHub.MasterDataService.Services.ArticleViews; 
@using System.Globalization
@inject IHtmlLocalizer<MasterDataServiceResource> L
@model EditModalModel
@{
    Layout = null;
}
<form data-ajaxForm="true" asp-page="/ArticleViews/EditModal" autocomplete="off">
    <abp-modal id="ArticleViewEditModal">
        <abp-modal-header title="@L["Update"].Value"></abp-modal-header>
        <abp-modal-body>
@*//<suite-custom-code-block-1>*@
@*//</suite-custom-code-block-1>*@
            <abp-input asp-for="Id" />
                    <abp-input asp-for="ArticleView.ConcurrencyStamp" hidden="true" suppress-label="true"/>
            <abp-input asp-for="ArticleView.IpAddress"    />
            <abp-input asp-for="ArticleView.Device"    />
            <abp-input asp-for="ArticleView.Source"    />
            <abp-date-picker auto-update-input="true" today-button-classes="btn-primary" asp-for="ArticleView.ViewedAt"  />
            <abp-input asp-for="ArticleView.Duration"    />
            <abp-input asp-for="ArticleView.UserId"    />
                                <abp-select asp-for="ArticleView.ArticleId" asp-items="Model.ArticleLookupListRequired" label="@L["Article"].Value"/>
@*//<suite-custom-code-block-2>*@
@*//</suite-custom-code-block-2>*@
@*//<suite-custom-code-block-3>*@
@*//</suite-custom-code-block-3>*@
        </abp-modal-body>
        <abp-modal-footer buttons="@(AbpModalButtons.Cancel|AbpModalButtons.Save)">
@*//<suite-custom-code-block-4>*@
@*//</suite-custom-code-block-4>*@
        </abp-modal-footer>
    </abp-modal>
</form>